{
  "name": "SyncSphere",
  "tagline": "Intelligence that evolves with your business",
  "version": "1.0.0",
  
  "colors": {
    "primary": {
      "purple": "#533afd",
      "purpleHover": "#4434d4",
      "purpleDeep": "#2e2b8c",
      "purpleLight": "#b9b9f9",
      "purpleMid": "#665efd"
    },
    "dark": {
      "navy": "#061b31",
      "darkNavy": "#0d253d",
      "brandDark": "#1c1e54"
    },
    "accent": {
      "magenta": "#f96bee",
      "magentaLight": "#ffd7ef",
      "ruby": "#ea2261"
    },
    "neutral": {
      "white": "#ffffff",
      "heading": "#061b31",
      "label": "#273951",
      "body": "#64748d",
      "border": "#e5edf5",
      "success": "#15be53",
      "successText": "#108c3d"
    },
    "shadow": {
      "blue": "rgba(50,50,93,0.25)",
      "darkBlue": "rgba(3,3,39,0.25)",
      "black": "rgba(0,0,0,0.1)",
      "ambient": "rgba(23,23,23,0.08)",
      "soft": "rgba(23,23,23,0.06)"
    }
  },

  "typography": {
    "fonts": {
      "primary": "'Source Sans 3', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "mono": "'Source Code Pro', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
    },
    "cdn": "https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500;600&family=Source+Code+Pro:wght@400;500;700&display=swap",
    "opentype": {
      "display": "\"ss01\"",
      "tabular": "\"tnum\""
    },
    "scale": {
      "hero": { "size": "56px", "weight": 300, "lineHeight": 1.03, "tracking": "-1.4px" },
      "display": { "size": "48px", "weight": 300, "lineHeight": 1.15, "tracking": "-0.96px" },
      "h1": { "size": "40px", "weight": 300, "lineHeight": 1.10, "tracking": "-0.8px" },
      "h2": { "size": "32px", "weight": 300, "lineHeight": 1.10, "tracking": "-0.64px" },
      "h3": { "size": "26px", "weight": 300, "lineHeight": 1.12, "tracking": "-0.26px" },
      "h4": { "size": "22px", "weight": 300, "lineHeight": 1.10, "tracking": "-0.22px" },
      "bodyLarge": { "size": "18px", "weight": 300, "lineHeight": 1.50, "tracking": "normal" },
      "body": { "size": "16px", "weight": 300, "lineHeight": 1.50, "tracking": "normal" },
      "small": { "size": "14px", "weight": 400, "lineHeight": 1.40, "tracking": "normal" },
      "caption": { "size": "12px", "weight": 400, "lineHeight": 1.33, "tracking": "normal" },
      "code": { "size": "12px", "weight": 500, "lineHeight": 2.00, "tracking": "normal" }
    }
  },

  "spacing": {
    "unit": "8px",
    "scale": [0, 4, 8, 12, 16, 24, 32, 40, 48, 56, 64, 80, 96, 120, 160]
  },

  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px",
    "full": "9999px"
  },

  "shadows": {
    "ambient": "0px 3px 6px rgba(23,23,23,0.06)",
    "card": "0px 15px 35px rgba(23,23,23,0.08)",
    "elevated": "0px 30px 45px -30px rgba(50,50,93,0.25), 0px 18px 36px -18px rgba(0,0,0,0.1)",
    "deep": "0px 14px 21px -14px rgba(3,3,39,0.25), 0px 8px 17px -8px rgba(0,0,0,0.1)",
    "focus": "0 0 0 2px #533afd"
  },

  "animation": {
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms",
      "slower": "800ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.175, 0.885, 0.32, 1.275)"
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  }
}
